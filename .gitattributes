# Normalize text files to LF in the repo. Working tree on Windows still
# checks out CRLF if core.autocrlf=true; we just refuse to store CRLF.
* text=auto eol=lf

# Generated lock files: keep their format intact.
pnpm-lock.yaml -text
package-lock.json -text

# Binary files: never normalize.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
