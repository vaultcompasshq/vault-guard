{
  "name": "vault-guard-vscode",
  "displayName": "Vault Guard",
  "description": "Inline secret diagnostics and local spend/status hints for Vault Guard",
  "version": "0.1.0",
  "publisher": "vaultcompass",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Vault Guard",
      "properties": {
        "vaultGuard.executable": {
          "type": "string",
          "default": "vault-guard",
          "description": "vault-guard CLI on PATH (used for statusline JSON integration)"
        }
      }
    },
    "commands": [
      {
        "command": "vaultGuard.copyAllowListSnippet",
        "title": "Vault Guard: Copy .vault-guard.json allow-list snippet"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --format=cjs",
    "vscode:prepublish": "pnpm run build",
    "package": "npx --yes @vscode/vsce package --no-dependencies",
    "publish": "npx --yes @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "@vaultcompass/vault-guard-core": "workspace:*",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultcompasshq/vault-guard.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/vaultcompasshq/vault-guard/issues"
  },
  "homepage": "https://github.com/vaultcompasshq/vault-guard#readme",
  "keywords": [
    "secrets",
    "security",
    "vault-guard",
    "linter",
    "ai"
  ]
}
