{
  "name": "@vaultcompass/vault-guard",
  "version": "1.0.4",
  "description": "Block secrets at commit and in CI. Pre-commit hooks, SARIF output, and fast staged-file scans for AI-native workflows.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultcompasshq/vault-guard.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/vaultcompasshq/vault-guard/issues"
  },
  "homepage": "https://github.com/vaultcompasshq/vault-guard#readme",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0",
    "pnpm": ">=9.0.0"
  },
  "bin": {
    "vault-guard": "./dist/cli-entry.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "security",
    "secret-scanner",
    "pre-commit-hook"
  ],
  "dependencies": {
    "@vaultcompass/vault-guard-core": "workspace:*",
    "@vaultcompass/vault-guard-telemetry": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  }
}
