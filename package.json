{
  "name": "@vaultcompass/vault-guard-monorepo",
  "version": "1.0.0",
  "description": "Security and optimization layer for AI-native coding (workspace root — not published)",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 run test:coverage",
    "test:windows": "pnpm --filter @vaultcompass/vault-guard-core test -- --testPathIgnorePatterns=pre-commit-hook && pnpm --filter @vaultcompass/vault-guard test -- --testPathIgnorePatterns=integration",
    "gen:rules-doc": "node scripts/gen-rules-doc.cjs",
    "lint": "eslint .",
    "check:pack": "node scripts/check-pack.cjs",
    "check:private-names": "node scripts/check-private-names.cjs",
    "prepublishOnly": "pnpm build",
    "release": "pnpm publish -r --access public",
    "bench": "node bench/run.cjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:next": "pnpm build && pnpm check:pack && pnpm publish -r --tag next --no-git-checks"
  },
  "keywords": [
    "cli",
    "security",
    "ai-coding",
    "guardrails",
    "secret-scanner",
    "token-optimization",
    "pre-commit-hook"
  ],
  "author": "Vault & Compass LLC",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "hono": "4.12.25"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
