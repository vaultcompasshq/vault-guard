{
  "name": "@vaultcompass/vault-guard-monorepo",
  "version": "1.0.0",
  "description": "Security and optimization layer for AI-native coding (workspace root \u2014 not published)",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 run test:coverage",
    "gen:rules-doc": "node scripts/gen-rules-doc.cjs",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "release": "pnpm publish -r --access public",
    "bench": "node bench/run.cjs"
  },
  "keywords": [
    "cli",
    "security",
    "ai-coding",
    "guardrails",
    "secret-scanner",
    "token-optimization",
    "pre-commit-hook"
  ],
  "author": "Vault & Compass LLC",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/jest": "^30.0.0",
    "typescript": "^5.0.0",
    "eslint": "^10.4.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@eslint/js": "^9.0.0",
    "jest": "^30.4.2"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
